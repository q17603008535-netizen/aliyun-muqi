---
interface PainItem {
  icon: string;
  text: string;
}

interface Props {
  painPoints?: {
    title?: string;
    pain_items?: PainItem[];
    solution_title?: string;
    solution_description?: string;
    enabled?: boolean;
  };
  contacts?: any[];
  urgencyMessage?: string;
}

const { painPoints = {}, contacts = [], urgencyMessage = "" } = Astro.props;

const iconMap: Record<string, string> = {
  '款式': 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10',
  '定制': 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
  '周期': 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  '效果': 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z',
  '价格': 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  '品质': 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  '真假': 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
  '选择': 'M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z',
};

const defaultPainItems: PainItem[] = [
  { icon: '款式', text: '商場成品款式千篇一律，缺乏個性' },
  { icon: '定制', text: '想要獨一無二的翡翠，但不知如何定制' },
  { icon: '周期', text: '擔心定制周期長、溝通成本高' },
  { icon: '效果', text: '擔心定制效果與想象不符' },
  { icon: '价格', text: '不確定定制是否真的物有所值' },
];

const title = painPoints.title || "您是否有以下困擾？";
const painItems = painPoints.pain_items?.length ? painPoints.pain_items : defaultPainItems;
const solutionTitle = painPoints.solution_title || "沐祁珠寶為您解決以上所有問題";
const solutionDescription = painPoints.solution_description || "10年+從業經驗，1000+成功案例";
const enabled = painPoints.enabled !== false;

if (!enabled) {
  return;
}
---

<section id="pain-points" class="py-16 bg-white fade-in-section">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      {urgencyMessage && (
        <div class="mb-4">
          <span class="inline-block px-4 py-1 bg-red-500/20 border border-red-500/30 rounded-full text-red-400 text-sm animate-pulse">
            {urgencyMessage}
          </span>
        </div>
      )}
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">{title}</h2>
      <div class="w-24 h-1 bg-primary mx-auto"></div>
    </div>
    
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {painItems.map((item, index) => (
        <div class="flex items-start gap-4 p-5 bg-red-50/50 rounded-xl border border-red-100 fade-in-section fade-in-delay-{(index % 3) + 1}">
          <div class="flex-shrink-0 w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconMap[item.icon] || iconMap['款式']} />
            </svg>
          </div>
          <p class="text-gray-700 font-medium leading-relaxed">{item.text}</p>
        </div>
      ))}
    </div>
    
    <div class="bg-gradient-to-r from-primary/10 to-primary/5 rounded-2xl p-8 text-center border border-primary/20 fade-in-section">
      <div class="w-16 h-16 bg-primary/20 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h3 class="text-2xl font-bold text-gray-900 mb-2">{solutionTitle}</h3>
      <p class="text-gray-600 mb-6">{solutionDescription}</p>
      <div class="flex flex-wrap justify-center gap-4 text-sm text-gray-500">
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          直播在線挑選，所見即所得
        </span>
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          15天快速交付
        </span>
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          全程跟蹤保證天然A貨
        </span>
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          附贈專業權威鑒定證書
        </span>
        <span class="flex items-center gap-1">
          <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          緬甸一手貨源
        </span>
      </div>
      
      <div class="mt-8">
        <a href="#contact" class="inline-flex items-center justify-center px-8 py-4 bg-primary text-white font-semibold rounded-lg btn-hover shadow-lg cursor-pointer transition-all duration-300 hover:scale-105">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
          立即咨詢定制
        </a>
      </div>
    </div>
  </div>
</section>
