---
interface Testimonial {
  name: string;
  location: string;
  content: string;
  rating: number;
}

interface Props {
  testimonials?: Testimonial[];
  title?: string;
}

const { 
  testimonials = [],
  title = "客戶見證" 
} = Astro.props;

const displayTestimonials = testimonials.length > 0 ? testimonials : [
  { name: "王小姐", location: "台灣", content: "經過朋友介紹認識了老板，買了3塊石頭都漲了！老板眼光很準，會推薦給朋友。", rating: 5 },
  { name: "陳先生", location: "香港", content: "本地匯率確實比外面便宜很多，而且老板很誠實，會如實告訴你石頭的風險。", rating: 5 },
  { name: "林小姐", location: "新加坡", content: "已經跟老板合作了3年，每年都會買幾塊做收藏。服務態度好，東西品質也有保障。", rating: 5 },
];
---

<section id="testimonials" class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">{title}</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        感謝客戶的信任與支持
      </p>
      <div class="w-24 h-1 bg-primary mx-auto mt-4"></div>
    </div>
    
    <div class="grid md:grid-cols-3 gap-8">
      {displayTestimonials.map((testimonial) => (
        <div class="bg-stone-50 p-6 rounded-xl">
          <div class="flex items-center gap-1 mb-4">
            {[...Array(5)].map((_, i) => (
              <svg class={`w-5 h-5 ${i < testimonial.rating ? 'text-amber-400' : 'text-gray-300'}`} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-gray-700 mb-4 leading-relaxed">"{testimonial.content}"</p>
          <div class="flex items-center justify-between">
            <div class="font-medium text-gray-900">{testimonial.name}</div>
            <div class="text-sm text-gray-500">{testimonial.location}</div>
          </div>
        </div>
      ))}
    </div>
    
    <div class="mt-12 text-center">
      <p class="text-gray-500 text-sm">
        更多真實客戶評價，可添加微信了解
      </p>
    </div>
  </div>
</section>
