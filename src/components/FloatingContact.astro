---
interface ContactItem {
  type: string;
  value: string;
  label: string;
  icon: string;
  visible: boolean;
  order: number;
}

interface Props {
  contacts?: ContactItem[];
}

const { contacts = [] } = Astro.props;
---

<div id="floating-contact" class="fixed z-40 hidden">
  <button id="floating-btn" class="fixed right-4 md:right-8 bottom-1/2 transform -translate-y-1/2 w-14 h-14 bg-primary hover:bg-primary-dark text-white rounded-full shadow-lg hover:shadow-xl transition-all duration-300 flex items-center justify-center cursor-pointer group">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
    </svg>
    <span class="absolute right-full mr-2 px-2 py-1 bg-gray-800 text-white text-xs rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap hidden md:block">
      立即咨询
    </span>
  </button>
</div>

<div id="floating-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm floating-modal-overlay"></div>
  <div class="flex items-center justify-center min-h-screen p-4">
    <div class="floating-modal-content relative bg-white rounded-2xl shadow-2xl max-w-md w-full p-6">
      <button class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 floating-close-btn">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      
      <h3 class="text-xl font-bold text-gray-900 mb-4 text-center">联系我们</h3>
      <p class="text-gray-600 text-center mb-6">点击即可一键复制</p>
      
      <div class="space-y-3">
        {contacts.length > 0 ? (
          contacts.map((contact) => (
            <button 
              class="contact-copy-btn w-full flex items-center gap-3 p-4 bg-gray-50 hover:bg-gray-100 rounded-xl transition-colors text-left"
              data-value={contact.value}
            >
              <div class="flex-shrink-0 w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                {contact.type === '微信' && (
                  <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 01.598.082l1.584.926a.272.272 0 00.14.045c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 01-.023-.156.49.49 0 01.201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-6.656-6.088V8.89c-.135.007-.264.029-.406.03zm-2.53 3.274c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.982.97-.982z"/>
                  </svg>
                )}
                {contact.type === 'LINE' && (
                  <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12.186 2.553c-1.562 0-2.882.477-4.012 1.164-1.193.724-1.802 1.75-1.802 2.927 0 1.28.582 2.4 1.358 3.274.906 1.016 1.99 1.794 3.052 2.38a.494.494 0 01.248.563l-.39 1.555c-.04.14-.123.206-.227.206a.287.287 0 01-.195-.083l-1.252-1.018a.862.862 0 00-.698-.332c-.41 0-.757.182-1.025.537-.248.33-.382.75-.382 1.236 0 .94.372 1.722 1.055 2.233l1.428 1.164c.566.45 1.175.683 1.818.683.61 0 1.175-.143 1.685-.415.503-.272.93-.647 1.288-1.133a.557.557 0 00.14-.166l.092-.382c.102-.422.05-.795-.155-1.116-.195-.305-.503-.46-.896-.46z"/>
                  </svg>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-medium text-gray-900 truncate">{contact.type}</p>
                <p class="text-sm text-gray-500 truncate">{contact.value}</p>
              </div>
              <div class="flex-shrink-0 text-green-600">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                </svg>
              </div>
            </button>
          ))
        ) : (
          <p class="text-center text-gray-500 py-4">请在后台添加联系方式</p>
        )}
      </div>
      
      <p class="mt-4 text-center text-green-600 text-sm floating-toast hidden">已复制到剪贴簿！</p>
    </div>
  </div>
</div>

<script>
  const floatingContact = document.getElementById('floating-contact');
  const floatingBtn = document.getElementById('floating-btn');
  const floatingModal = document.getElementById('floating-modal');
  const floatingCloseBtn = document.querySelector('.floating-close-btn');
  const floatingOverlay = document.querySelector('.floating-modal-overlay');
  const floatingModalContent = document.querySelector('.floating-modal-content');
  const floatingToast = document.querySelector('.floating-toast');
  
  function showFloatingBtn() {
    floatingContact?.classList.remove('hidden');
  }
  
  function hideFloatingBtn() {
    floatingContact?.classList.add('hidden');
  }
  
  function openModal() {
    floatingModal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => {
      floatingModalContent?.classList.add('modal-enter');
    });
  }
  
  function closeModal() {
    floatingModalContent?.classList.remove('modal-enter');
    floatingModalContent?.classList.add('modal-exit');
    setTimeout(() => {
      floatingModal?.classList.add('hidden');
      document.body.style.overflow = '';
      floatingModalContent?.classList.remove('modal-exit');
    }, 300);
  }
  
  window.addEventListener('scroll', () => {
    const heroHeight = window.innerHeight * 0.7;
    if (window.scrollY > heroHeight) {
      showFloatingBtn();
    } else {
      hideFloatingBtn();
    }
  });
  
  floatingBtn?.addEventListener('click', openModal);
  floatingCloseBtn?.addEventListener('click', closeModal);
  floatingOverlay?.addEventListener('click', closeModal);
  
  document.querySelectorAll('.contact-copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const value = btn.getAttribute('data-value');
      if (value) {
        try {
          await navigator.clipboard.writeText(value);
          floatingToast?.classList.remove('hidden');
          setTimeout(() => {
            floatingToast?.classList.add('hidden');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      }
    });
  });
  
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
