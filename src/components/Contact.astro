---
interface ContactItem {
  type: string;
  value: string;
  label: string;
  icon: string;
  visible: boolean;
  order: number;
}

interface Props {
  contacts?: ContactItem[];
}

const { contacts = [] } = Astro.props;
---

<section id="contact" class="py-20 bg-stone-50 fade-in-section" aria-labelledby="contact-heading">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 id="contact-heading" class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">聯繫我們</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        歡迎隨時咨詢，我們將竭誠為您服務
      </p>
      <div class="w-24 h-1 bg-primary mx-auto mt-4"></div>
    </div>
    
    <div class="grid lg:grid-cols-2 gap-12">
      <div>
    <h3 class="text-xl font-semibold text-gray-900 mb-6">在線咨詢</h3>
    <form 
      id="contact-form" 
      action="https://api.web3forms.com/submit"
      method="POST"
      class="space-y-4"
      aria-label="咨詢表單"
    >
      <!-- Web3Forms Access Key -->
      <input type="hidden" name="access_key" value="4cedbff2-2131-4500-bfc1-7fc950517f48" />
      <input type="hidden" name="subject" value="网站咨询 - 翡翠原石" />
      <input type="hidden" name="replyto" value="email" />
      
      <div>
        <label for="name" class="block text-sm font-medium text-gray-700 mb-1">姓名 <span aria-hidden="true">*</span></label>
        <input type="text" id="name" name="name" required
          class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-colors"
          placeholder="請輸入您的姓名"
          aria-required="true"
          aria-describedby="name-error" />
      </div>
      
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email <span aria-hidden="true">*</span></label>
        <input type="email" id="email" name="email" required
          class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-colors"
          placeholder="your@email.com"
          aria-required="true"
          aria-describedby="email-error" />
      </div>
      
      <div>
        <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">電話（可選）</label>
        <input type="tel" id="phone" name="phone"
          class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-colors"
          placeholder="+886 9xxxxxxxx"
          aria-describedby="phone-hint" />
        <p id="phone-hint" class="mt-1 text-sm text-gray-500">選填，方便我們與您聯繫</p>
      </div>
      
      <div>
        <label for="message" class="block text-sm font-medium text-gray-700 mb-1">留言 <span aria-hidden="true">*</span></label>
        <textarea id="message" name="message" rows="4" required
          class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary transition-colors"
          placeholder="請告訴我們您想了解的翡翠原石信息..."
          aria-required="true"
          aria-describedby="message-error"></textarea>
      </div>
      
      <button type="submit" 
        class="w-full px-6 py-4 bg-primary text-white font-medium rounded-lg btn-hover shadow-lg"
        aria-label="發送咨詢表單">
        發送咨詢
      </button>
      
      <div id="form-status" role="status" aria-live="polite" class="hidden"></div>
    </form>
  </div>
      
      <div class="flex flex-col h-full">
        <h3 class="text-xl font-semibold text-gray-900 mb-6">聯繫方式</h3>
        
        <!-- 商家名称醒目展示 -->
        <div class="bg-gradient-to-r from-primary/10 to-secondary/10 border-2 border-primary/30 rounded-xl p-5 mb-4 text-center">
          <p class="text-2xl font-bold text-primary mb-0.5">洛天翡翠</p>
          <p class="text-xs text-gray-600">曼德勒翡翠原石專業代購</p>
        </div>
        
        <div class="space-y-4 flex-1">
          {contacts.length > 0 ? (
            contacts.map((contact) => (
              <div class="bg-white p-5 rounded-xl shadow-sm hover:shadow-md transition-shadow">
                <div class="flex items-start gap-3">
                  <div class="flex-shrink-0 w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center" aria-hidden="true">
                    {contact.type === '微信' && (
                      <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 01.598.082l1.584.926a.272.272 0 00.14.045c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 01-.023-.156.49.49 0 01.201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-6.656-6.088V8.89c-.135.007-.264.029-.406.03zm-2.53 3.274c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.982.97-.982z"/>
                      </svg>
                    )}
                    {contact.type === 'LINE' && (
                      <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12.186 2.553c-1.562 0-2.882.477-4.012 1.164-1.193.724-1.802 1.75-1.802 2.927 0 1.28.582 2.4 1.358 3.274.906 1.016 1.99 1.794 3.052 2.38a.494.494 0 01.248.563l-.39 1.555c-.04.14-.123.206-.227.206a.287.287 0 01-.195-.083l-1.252-1.018a.862.862 0 00-.698-.332c-.41 0-.757.182-1.025.537-.248.33-.382.75-.382 1.236 0 .94.372 1.722 1.055 2.233l1.428 1.164c.566.45 1.175.683 1.818.683.61 0 1.175-.143 1.685-.415.503-.272.93-.647 1.288-1.133a.557.557 0 00.14-.166l.092-.382c.102-.422.05-.795-.155-1.116-.195-.305-.503-.46-.896-.46z"/>
                      </svg>
                    )}
                    {contact.type === 'Email' && (
                      <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                      </svg>
                    )}
                    {contact.type === '電話' && (
                      <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                      </svg>
                    )}
                    {contact.type === '地址' && (
                      <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </svg>
                    )}
                  </div>
                  <div class="flex-1">
                    <h4 class="font-medium text-gray-900 mb-0.5 text-sm">{contact.type}</h4>
                    <p class="text-gray-600 text-sm">{contact.value}</p>
                  </div>
                </div>
              </div>
            ))
          ) : (
            <div class="bg-white p-5 rounded-xl shadow-sm">
              <p class="text-gray-500 text-center text-sm">請在後台添加聯繫方式</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form');
  const formStatus = document.getElementById('form-status');
  
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const submitButton = form.querySelector('button[type="submit"]');
      const originalText = submitButton.textContent;
      
      // 禁用按钮，显示提交中
      submitButton.disabled = true;
      submitButton.textContent = '提交中...';
      submitButton.classList.add('opacity-50', 'cursor-not-allowed');
      
      try {
        const formData = new FormData(form);
        
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json'
          }
        });
        
        if (response.ok) {
          // 成功 - 跳转到感谢页面
          window.location.href = '/thank-you';
        } else {
          // 失败 - 显示错误提示
          formStatus.textContent = '❌ 提交失敗，請稍後再試。';
          formStatus.className = 'p-4 bg-red-100 text-red-700 rounded-lg text-center font-medium';
          formStatus.classList.remove('hidden');
          
          // 恢复按钮
          submitButton.disabled = false;
          submitButton.textContent = originalText;
          submitButton.classList.remove('opacity-50', 'cursor-not-allowed');
          
          // 3秒后隐藏提示
          setTimeout(() => {
            formStatus.classList.add('hidden');
          }, 3000);
        }
      } catch (error) {
        // 网络错误
        formStatus.textContent = '❌ 網絡錯誤，請檢查網絡連接。';
        formStatus.className = 'p-4 bg-red-100 text-red-700 rounded-lg text-center font-medium';
        formStatus.classList.remove('hidden');
        
        // 恢复按钮
        submitButton.disabled = false;
        submitButton.textContent = originalText;
        submitButton.classList.remove('opacity-50', 'cursor-not-allowed');
        
        // 3秒后隐藏提示
        setTimeout(() => {
          formStatus.classList.add('hidden');
        }, 3000);
      }
    });
  }
</script>
