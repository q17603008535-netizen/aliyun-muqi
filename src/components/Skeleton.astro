---
interface Props {
  type?: 'card' | 'text' | 'circle' | 'rectangle' | 'product-card';
  count?: number;
  width?: string;
  height?: string;
  className?: string;
}

const {
  type = 'text',
  count = 1,
  width,
  height,
  className = ''
} = Astro.props;

const getSkeletonClasses = (type: string) => {
  switch (type) {
    case 'card':
      return 'bg-gray-200 rounded-xl';
    case 'product-card':
      return 'bg-gray-200 rounded-xl';
    case 'circle':
      return 'bg-gray-200 rounded-full';
    case 'rectangle':
      return 'bg-gray-200 rounded-lg';
    case 'text':
    default:
      return 'bg-gray-200 rounded';
  }
};

const getDefaultDimensions = (type: string) => {
  switch (type) {
    case 'card':
      return { width: '100%', height: '200px' };
    case 'product-card':
      return { width: '100%', height: '300px' };
    case 'circle':
      return { width: '64px', height: '64px' };
    case 'rectangle':
      return { width: '100%', height: '100px' };
    case 'text':
    default:
      return { width: '100%', height: '1rem' };
  }
};

const defaultDims = getDefaultDimensions(type);
const skeletonClasses = getSkeletonClasses(type);
---

<div class={`space-y-${type === 'product-card' ? '4' : '3'} ${className}`}>
  {Array.from({ length: count }).map((_, index) => (
    <div 
      key={index}
      class={`animate-pulse ${skeletonClasses}`}
      style={{
        width: width || defaultDims.width,
        height: height || defaultDims.height
      }}
    >
      {type === 'product-card' && (
        <div class="h-full flex flex-col">
          <div class="h-48 bg-gray-300 rounded-t-xl"></div>
          <div class="p-4 space-y-3">
            <div class="h-4 bg-gray-300 rounded w-3/4"></div>
            <div class="h-3 bg-gray-300 rounded w-1/2"></div>
            <div class="h-3 bg-gray-300 rounded w-5/6"></div>
          </div>
        </div>
      )}
    </div>
  ))}
</div>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  .animate-pulse {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>