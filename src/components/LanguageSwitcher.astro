---
// 语言切换器组件 - 简洁缩写版
interface Props {
  currentLocale: string;
}

const { currentLocale = 'zh-TW' } = Astro.props;

const languages = [
  { code: 'zh-TW', label: 'TW' },
  { code: 'zh-CN', label: 'CN' },
  { code: 'en', label: 'EN' },
];
---

<div class="language-switcher relative inline-block" id="language-switcher">
  <!-- 主按钮 - 圆角正方形 -->
  <button
    id="language-toggle"
    class="w-10 h-10 flex items-center justify-center bg-white/10 hover:bg-white/20 rounded-lg transition-all duration-200 border border-white/20 hover:border-white/40"
    aria-label="切換語言"
    aria-expanded="false"
    aria-haspopup="true"
  >
    <span class="text-sm font-medium text-white">
      {languages.find(l => l.code === currentLocale)?.label}
    </span>
  </button>
  
  <!-- 下拉菜单 -->
  <div
    id="language-dropdown"
    class="absolute right-0 mt-2 w-20 bg-white rounded-lg shadow-xl border border-gray-200 py-1 opacity-0 invisible transform -translate-y-2 transition-all duration-200 z-50"
    role="menu"
    aria-labelledby="language-toggle"
  >
    {languages.map((lang) => (
      <button
        type="button"
        data-locale={lang.code}
        class="w-full px-4 py-2 text-sm hover:bg-gray-100 transition-colors cursor-pointer text-left flex items-center justify-center gap-2"
        role="menuitem"
        aria-label={`切換到${lang.label}`}
      >
        <span class="font-medium text-gray-700">{lang.label}</span>
        {lang.code === currentLocale && (
          <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
        )}
      </button>
    ))}
  </div>
</div>

<script>
  const switcher = document.getElementById('language-switcher');
  const toggle = document.getElementById('language-toggle');
  const dropdown = document.getElementById('language-dropdown');
  let hideTimeout: number | null = null;
  
  function showDropdown() {
    if (hideTimeout) {
      clearTimeout(hideTimeout);
      hideTimeout = null;
    }
    dropdown?.classList.remove('opacity-0', 'invisible', '-translate-y-2');
    dropdown?.classList.add('opacity-100', 'visible', 'translate-y-0');
    toggle?.setAttribute('aria-expanded', 'true');
  }
  
  function hideDropdown() {
    hideTimeout = window.setTimeout(() => {
      dropdown?.classList.add('opacity-0', 'invisible', '-translate-y-2');
      dropdown?.classList.remove('opacity-100', 'visible', 'translate-y-0');
      toggle?.setAttribute('aria-expanded', 'false');
    }, 100); // 100ms 延迟，避免误触
  }
  
  // 鼠标进入按钮区域 - 显示菜单
  toggle?.addEventListener('mouseenter', () => {
    showDropdown();
  });
  
  // 鼠标离开按钮区域 - 延迟隐藏
  toggle?.addEventListener('mouseleave', () => {
    hideDropdown();
  });
  
  // 鼠标进入下拉菜单 - 保持显示
  dropdown?.addEventListener('mouseenter', () => {
    if (hideTimeout) {
      clearTimeout(hideTimeout);
      hideTimeout = null;
    }
  });
  
  // 鼠标离开下拉菜单 - 隐藏
  dropdown?.addEventListener('mouseleave', () => {
    hideDropdown();
  });
  
  // 点击外部关闭
  document.addEventListener('click', (e) => {
    if (switcher && !switcher.contains(e.target as Node)) {
      hideDropdown();
    }
  });
  
  // 键盘导航
  toggle?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      showDropdown();
      // 聚焦到第一个选项
      const firstItem = dropdown?.querySelector('button[data-locale]') as HTMLElement;
      firstItem?.focus();
    }
    if (e.key === 'Escape') {
      hideDropdown();
      toggle?.focus();
    }
  });
  
  // 语言切换功能
  document.querySelectorAll('[data-locale]').forEach(button => {
    button.addEventListener('click', () => {
      const locale = (button as HTMLElement).getAttribute('data-locale');
      if (locale) {
        // 保存用户偏好
        localStorage.setItem('preferred-locale', locale);
        
        // 更新 URL
        const currentPath = window.location.pathname;
        const pathParts = currentPath.split('/').filter(Boolean);
        
        // 移除现有的语言前缀
        let basePath = currentPath;
        if (['zh-TW', 'zh-CN', 'en'].includes(pathParts[0])) {
          basePath = '/' + pathParts.slice(1).join('/');
        }
        
        // 构建新路径
        let newPath = basePath;
        if (locale !== 'zh-TW') { // 默认语言不使用前缀
          newPath = '/' + locale + basePath;
        }
        
        // 更新 URL 并刷新
        window.location.href = newPath;
      }
    });
  });
</script>

<style>
  /* 平滑动画 */
  #language-dropdown {
    transition: all 0.2s ease-out;
  }
  
  /* 焦点状态 */
  #language-toggle:focus {
    outline: 2px solid rgba(26, 95, 74, 0.5);
    outline-offset: 2px;
  }
  
  /* 菜单项焦点 */
  #language-dropdown button:focus {
    outline: 2px solid rgba(26, 95, 74, 0.5);
    outline-offset: -2px;
  }
</style>
