---
import { Image } from 'astro:assets';

interface HeroData {
  background_image?: string;
  mobile_background_image?: string;
  title_lines?: { text: string }[];
  title_lines_mobile?: { text: string }[];
  subtitle_lines?: { text: string }[];
  subtitle_lines_mobile?: { text: string }[];
  cta_text?: string;
  badge_text?: string;
  youtube_url?: string;
}

interface ContactItem {
  type: string;
  value: string;
  label: string;
  icon: string;
  visible: boolean;
  order: number;
}

interface Props {
  hero?: HeroData;
  contacts?: ContactItem[];
}

const { hero = {}, contacts = [] } = Astro.props;

const defaultTitleLinesMobile = [
  { text: '專業翡翠原石買手' },
  { text: '曼德勒直採' },
];

const defaultSubtitleLinesMobile = [
  { text: '本地匯率優勢' },
  { text: '一物一證' },
];

const titleLinesMobile = hero.title_lines_mobile?.length ? hero.title_lines_mobile : defaultTitleLinesMobile;
const subtitleLinesMobile = hero.subtitle_lines_mobile?.length ? hero.subtitle_lines_mobile : defaultSubtitleLinesMobile;

const defaultTitleLines = [
  { text: '專業翡翠原石買手' },
  { text: '曼德勒直採｜10年經驗' },
];

const defaultSubtitleLines = [
  { text: '本地匯率優勢' },
  { text: '一物一證｜只賺取20%代購費' },
];

const titleLines = hero.title_lines?.length ? hero.title_lines : defaultTitleLines;
const subtitleLines = hero.subtitle_lines?.length ? hero.subtitle_lines : defaultSubtitleLines;
---

<section id="hero" class="relative min-h-[70vh] flex items-center justify-center bg-gradient-to-br from-stone-900 via-stone-800 to-stone-900 overflow-hidden pt-16 pb-20 md:pt-0 md:pb-0">
  {hero.background_image || hero.mobile_background_image ? (
    <div class="absolute inset-0">
      {hero.mobile_background_image && (
        <Image 
          src={hero.mobile_background_image} 
          alt="手機背景" 
          width={750}
          height={1334}
          loading="eager"
          decoding="async"
          fetchpriority="high"
          sizes="(max-width: 768px) 100vw, 0px"
          formats={['avif', 'webp', 'original']}
          quality={85}
          class="md:hidden w-full h-full object-cover opacity-30" 
        />
      )}
      {hero.background_image && (
        <Image 
          src={hero.background_image} 
          alt="電腦背景" 
          width={1920}
          height={1080}
          loading="eager"
          decoding="async"
          fetchpriority="high"
          sizes="(min-width: 769px) 100vw, 0px"
          formats={['avif', 'webp', 'original']}
          quality={85}
          class="hidden md:block w-full h-full object-cover opacity-30" 
        />
      )}
    </div>
  ) : (
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20width%3D%2260%22%20height%3D%2260%22%20viewBox%3D%220%200%2060%2060%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cg%20fill%3D%22none%22%20fill-rule%3D%22evenodd%22%3E%3Cg%20fill%3D%22%23d4a574%22%20fill-opacity%3D%220.3%22%3E%3Cpath%20d%3D%22M36%2034v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6%2034v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6%204V0H4v4H0v2h4v4h2V6h4V4H6z%22%2F%3E%3C%2Fg%3E%3C%2Fg%3E%3C%2Fsvg%3E')]"></div>
    </div>
  )}

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="mb-4 sm:mb-6">
      <div class="inline-block px-3 sm:px-4 py-1.5 sm:py-2 bg-primary/20 border border-primary/30 rounded-full text-secondary text-xs sm:text-sm">
        {hero.badge_text || "曼德勒翡翠原石專業代購"}
      </div>
    </div>
    
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-3 sm:mb-4 leading-tight text-center">
      <span class="hidden md:inline">
        {titleLines.map((line, index) => (
          <span class="block">{line.text}</span>
        ))}
      </span>
      <span class="md:hidden">
        {titleLinesMobile.map((line, index) => (
          <span class="block">{line.text}</span>
        ))}
      </span>
    </h1>
    
    <p class="text-lg sm:text-xl text-stone-300 mb-6 sm:mb-8 max-w-2xl mx-auto text-center">
      <span class="hidden md:inline">
        {subtitleLines.map((line, index) => (
          <span class="block">{line.text}</span>
        ))}
      </span>
      <span class="md:hidden">
        {subtitleLinesMobile.map((line, index) => (
          <span class="block">{line.text}</span>
        ))}
      </span>
    </p>
    
    <div class="flex gap-4 justify-center items-center flex-wrap">
      <button id="contact-modal-btn" class="inline-flex items-center justify-center px-6 sm:px-8 py-3 sm:py-4 bg-primary text-white font-medium rounded-lg btn-hover shadow-lg cursor-pointer">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        {hero.cta_text || "立即咨詢"}
      </button>
      <a href="#products" class="inline-flex items-center justify-center px-6 sm:px-8 py-3 sm:py-4 border border-primary text-primary hover:bg-white hover:text-primary font-medium rounded-lg btn-hover">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        查看產品
      </a>
    </div>
</section>

<div id="contact-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm modal-overlay" id="modal-overlay"></div>
  <div class="flex items-center justify-center min-h-screen p-4">
    <div class="modal-content relative bg-white rounded-2xl shadow-2xl max-w-md w-full p-6">
      <button class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 close-modal-btn">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      
      <h3 class="text-xl font-bold text-gray-900 mb-4 text-center">聯繫我們</h3>
      <p class="text-gray-600 text-center mb-6">點擊即可一鍵複製</p>
      
      <div class="space-y-3">
        {contacts.length > 0 ? (
          contacts.map((contact) => (
            <button 
              class="contact-copy-btn w-full flex items-center gap-3 p-4 bg-gray-50 hover:bg-gray-100 rounded-xl transition-colors text-left"
              data-value={contact.value}
            >
              <div class="flex-shrink-0 w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                {contact.type === '微信' && (
                  <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 01.598.082l1.584.926a.272.272 0 00.14.045c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 01-.023-.156.49.49 0 01.201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-6.656-6.088V8.89c-.135.007-.264.029-.406.03zm-2.53 3.274c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.982.97-.982z"/>
                  </svg>
                )}
                {contact.type === 'LINE' && (
                  <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12.186 2.553c-1.562 0-2.882.477-4.012 1.164-1.193.724-1.802 1.75-1.802 2.927 0 1.28.582 2.4 1.358 3.274.906 1.016 1.99 1.794 3.052 2.38a.494.494 0 01.248.563l-.39 1.555c-.04.14-.123.206-.227.206a.287.287 0 01-.195-.083l-1.252-1.018a.862.862 0 00-.698-.332c-.41 0-.757.182-1.025.537-.248.33-.382.75-.382 1.236 0 .94.372 1.722 1.055 2.233l1.428 1.164c.566.45 1.175.683 1.818.683.61 0 1.175-.143 1.685-.415.503-.272.93-.647 1.288-1.133a.557.557 0 00.14-.166l.092-.382c.102-.422.05-.795-.155-1.116-.195-.305-.503-.46-.896-.46z"/>
                  </svg>
                )}
                {contact.type === 'Email' && (
                  <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                )}
                {contact.type === '電話' && (
                  <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                )}
                {contact.type === '地址' && (
                  <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-medium text-gray-900 truncate">{contact.type}</p>
                <p class="text-sm text-gray-500 truncate">{contact.value}</p>
              </div>
              <div class="flex-shrink-0 text-green-600">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                </svg>
              </div>
            </button>
          ))
        ) : (
          <p class="text-center text-gray-500 py-4">請在後台添加聯繫方式</p>
        )}
      </div>
      
      <p id="copy-toast" class="mt-4 text-center text-green-600 text-sm hidden">已複製到剪貼簿！</p>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('contact-modal');
  const modalBtn = document.getElementById('contact-modal-btn');
  const closeBtn = document.querySelector('.close-modal-btn');
  const overlay = document.querySelector('.modal-overlay');
  const modalContent = document.querySelector('.modal-content');
  const copyToast = document.getElementById('copy-toast');
  
  function openModal() {
    modal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => {
      modalContent?.classList.add('modal-enter');
    });
  }
  
  function closeModal() {
    modalContent?.classList.remove('modal-enter');
    modalContent?.classList.add('modal-exit');
    setTimeout(() => {
      modal?.classList.add('hidden');
      document.body.style.overflow = '';
      modalContent?.classList.remove('modal-exit');
    }, 300);
  }
  
  modalBtn?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  overlay?.addEventListener('click', closeModal);
  
  document.querySelectorAll('.contact-copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const value = btn.getAttribute('data-value');
      if (value) {
        try {
          await navigator.clipboard.writeText(value);
          copyToast?.classList.remove('hidden');
          setTimeout(() => {
            copyToast?.classList.add('hidden');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      }
    });
  });
  
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
