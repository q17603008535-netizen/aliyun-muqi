---
interface TrustItem {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  trust?: {
    title?: string;
    items?: TrustItem[];
  };
}

const { trust = {} } = Astro.props;

const iconMap: Record<string, { bg: string; color: string; svg: string }> = {
  '盾牌': { bg: 'bg-green-100', color: 'text-green-600', svg: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
  '貨幣': { bg: 'bg-blue-100', color: 'text-blue-600', svg: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
  '證書': { bg: 'bg-yellow-100', color: 'text-yellow-600', svg: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z' },
  '循環': { bg: 'bg-purple-100', color: 'text-purple-600', svg: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
  '商務': { bg: 'bg-red-100', color: 'text-red-600', svg: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
  '切割': { bg: 'bg-indigo-100', color: 'text-indigo-600', svg: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  '礦石': { bg: 'bg-stone-100', color: 'text-stone-600', svg: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z' },
  '眼睛': { bg: 'bg-cyan-100', color: 'text-cyan-600', svg: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z' },
  '星星': { bg: 'bg-amber-100', color: 'text-amber-500', svg: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z' },
  '握手': { bg: 'bg-teal-100', color: 'text-teal-600', svg: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1' },
};

const defaultItems = [
  { icon: '盾牌', title: '一物一證', description: '每件翡翠原石均附帶專業鑒定證書，保證天然A貨，品質有保障' },
  { icon: '貨幣', title: '本地匯率', description: '緬甸本地匯率，比國際匯率低近 50%，價格更優惠' },
  { icon: '循環', title: '7天鑑賞期', description: '提供7天無條件退換貨服務，讓您有充足時間考慮' },
  { icon: '商務', title: '代購費透明', description: '只賺取 20% 代購費，絕不額外收費' },
  { icon: '商務', title: '瑞麗公司', description: '瑞麗設有分公司，正規經營，誠信可靠' },
  { icon: '切割', title: '加工廠合作', description: '與專業加工廠合作，提供切割、雕刻等一站式服務' },
];

const items = trust.items?.length ? trust.items : defaultItems;
---

<section id="trust" class="py-20 bg-stone-50 fade-in-section">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4 fade-in-section fade-in-delay-1">{trust.title || "信任保證"}</h2>
      <p class="text-gray-600 max-w-2xl mx-auto fade-in-section fade-in-delay-2">
        選擇我們的信心保障
      </p>
      <div class="w-24 h-1 bg-primary mx-auto mt-4 fade-in-section fade-in-delay-3"></div>
    </div>
    
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map((item, index) => {
        const iconData = iconMap[item.icon] || iconMap['盾牌'];
        return (
          <div class={`bg-white p-6 rounded-xl shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1 fade-in-section fade-in-delay-${(index % 3) + 1}`}>
            <div class={`w-14 h-14 ${iconData.bg} rounded-lg flex items-center justify-center mb-4`}>
              <svg class={`w-7 h-7 ${iconData.color}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconData.svg} />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm">{item.description}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
