---
interface GiftItem {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  freeGifts?: {
    title?: string;
    subtitle?: string;
    gifts?: GiftItem[];
    cta_text?: string;
    enabled?: boolean;
  };
  contacts?: any[];
  urgencyMessage?: string;
}

const { freeGifts = {}, contacts = [], urgencyMessage = "" } = Astro.props;

const iconMap: Record<string, string> = {
  '鉴定': 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  '设计': 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
  '手册': 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
  '优惠券': 'M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 002 2 2 2 0 010 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 010-4 2 2 0 00-2-2H5z',
  '原石': 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
  '证书': 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',
};

const defaultGifts: GiftItem[] = [
  { icon: '鉴定', title: '免費翡翠真假鑒定', description: '拍照發微信，專業幫您判斷真假' },
  { icon: '设计', title: '免費定制方案設計', description: '10年+經驗設計師為您量身定制' },
  { icon: '手册', title: '《10年+翡翠知識經驗手冊》', description: '精選翡翠鑒賞乾貨，助您避坑' },
  { icon: '优惠券', title: '首次定制專享優惠券', description: '限時領取，最高可減1000元' },
];

const title = freeGifts.title || "今日加微信，免費獲取";
const subtitle = freeGifts.subtitle || "限量供應，錯過不再";
const gifts = freeGifts.gifts?.length ? freeGifts.gifts : defaultGifts;
const ctaText = freeGifts.cta_text || "立即領取";
const enabled = freeGifts.enabled !== false;

if (!enabled) {
  return;
}
---

<section id="free-gifts" class="py-16 bg-gradient-to-b from-stone-900 to-stone-800 fade-in-section">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    {urgencyMessage && (
      <div class="text-center mb-6">
        <span class="inline-block px-4 py-1 bg-red-500/20 border border-red-500/30 rounded-full text-red-400 text-sm animate-pulse">
          {urgencyMessage}
        </span>
      </div>
    )}
    
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-3">{title}</h2>
      <p class="text-amber-400 text-lg">{subtitle}</p>
      <div class="w-24 h-1 bg-primary mx-auto mt-4"></div>
    </div>
    
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {gifts.map((gift, index) => (
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 text-center border border-white/20 card-hover fade-in-section fade-in-delay-{(index % 4) + 1}">
          <div class="w-16 h-16 bg-primary/20 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconMap[gift.icon] || iconMap['手册']} />
            </svg>
          </div>
          <h3 class="text-white font-semibold mb-2">{gift.title}</h3>
          <p class="text-stone-300 text-sm">{gift.description}</p>
        </div>
      ))}
    </div>
    
    <div class="mt-10 text-center">
      <button 
        id="free-gifts-cta-btn"
        class="inline-flex items-center justify-center px-8 py-4 bg-primary text-white font-semibold rounded-lg btn-hover shadow-lg cursor-pointer transition-all duration-300 hover:scale-105"
      >
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
        </svg>
        {ctaText}
      </button>
      <p class="text-stone-400 text-sm mt-3">長按識別二維碼 或 點擊按鈕獲取</p>
    </div>
  </div>
</section>

<div id="free-gifts-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/60 backdrop-blur-sm modal-overlay"></div>
  <div class="flex items-center justify-center min-h-screen p-4">
    <div class="modal-content relative bg-white rounded-2xl shadow-2xl max-w-md w-full p-6">
      <button class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 free-gifts-modal-close">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      
      <h3 class="text-xl font-bold text-gray-900 mb-4 text-center">聯繫我們獲取免費好禮</h3>
      <p class="text-gray-600 text-center mb-6">選擇您方便的聯繫方式</p>
      
      <div class="space-y-3">
        {contacts.length > 0 ? (
          contacts.map((contact) => (
            <button 
              class="contact-copy-btn w-full flex items-center gap-3 p-4 bg-gray-50 hover:bg-gray-100 rounded-xl transition-colors text-left"
              data-value={contact.value}
            >
              <div class="flex-shrink-0 w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center">
                {contact.type === '微信' && (
                  <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348z"/>
                  </svg>
                )}
                {contact.type === 'LINE' && (
                  <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12.186 2.553c-1.562 0-2.882.477-4.012 1.164-1.193.724-1.802 1.75-1.802 2.927 0 1.28.582 2.4 1.358 3.274.906 1.016 1.99 1.794 3.052 2.38a.494.494 0 01.248.563l-.39 1.555c-.04.14-.123.206-.227.206a.287.287 0 01-.195-.083l-1.252-1.018a.862.862 0 00-.698-.332c-.41 0-.757.182-1.025.537-.248.33-.382.75-.382 1.236 0 .94.372 1.722 1.055 2.233l1.428 1.164c.566.45 1.175.683 1.818.683.61 0 1.175-.143 1.685-.415.503-.272.93-.647 1.288-1.133a.557.557 0 00.14-.166l.092-.382c.102-.422.05-.795-.155-1.116-.195-.305-.503-.46-.896-.46z"/>
                  </svg>
                )}
                {contact.type === '電話' && (
                  <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                )}
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-medium text-gray-900 truncate">{contact.type}</p>
                <p class="text-sm text-gray-500 truncate">{contact.value}</p>
              </div>
              <div class="flex-shrink-0 text-green-600">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                </svg>
              </div>
            </button>
          ))
        ) : (
          <p class="text-center text-gray-500 py-4">請在後台添加聯繫方式</p>
        )}
      </div>
      
      <p id="free-gifts-copy-toast" class="mt-4 text-center text-green-600 text-sm hidden">已複製到剪貼簿！</p>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById('free-gifts-modal');
  const modalBtn = document.getElementById('free-gifts-cta-btn');
  const closeBtn = document.querySelector('.free-gifts-modal-close');
  const copyToast = document.getElementById('free-gifts-copy-toast');
  
  function openModal() {
    modal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  
  function closeModal() {
    modal?.classList.add('hidden');
    document.body.style.overflow = '';
  }
  
  modalBtn?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  modal?.querySelector('.modal-overlay')?.addEventListener('click', closeModal);
  
  modal?.querySelectorAll('.contact-copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const value = btn.getAttribute('data-value');
      if (value) {
        try {
          await navigator.clipboard.writeText(value);
          copyToast?.classList.remove('hidden');
          setTimeout(() => {
            copyToast?.classList.add('hidden');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      }
    });
  });
  
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal?.classList.contains('hidden')) {
      closeModal();
    }
  });
</script>
