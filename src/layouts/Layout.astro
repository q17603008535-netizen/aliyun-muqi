---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  type?: string;
  publishedTime?: string;
}

const { 
  title, 
  description = "翡翠原石代購｜曼德勒專業買手｜10 年經驗",
  image,
  canonicalURL,
  type = 'website',
  publishedTime
} = Astro.props;

// 获取追踪代码配置
const trackingCodesCollection = await getCollection('tracking_codes');
const trackingCodes = trackingCodesCollection.find(c => c.id === 'config' || c.slug === 'config');
const headScripts = trackingCodes?.data.head_scripts || '';
const bodyScripts = trackingCodes?.data.body_scripts || '';
const footScripts = trackingCodes?.data.foot_scripts || '';
---

<!-- 跳过链接 - 无障碍功能 -->
<a href="#main-content" class="skip-link">
  跳转到主要内容
</a>

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link 
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&display=swap" 
      rel="stylesheet" 
    />
    <style>
      /* 字体加载优化 - 避免 FOIT */
      @font-face {
        font-family: 'Noto Sans TC Fallback';
        src: local('Arial');
        ascent-override: 100%;
        descent-override: 30%;
        line-gap-override: 0%;
        size-adjust: 107%;
      }
      html {
        font-family: 'Noto Sans TC Fallback', sans-serif;
      }
      html.loaded {
        font-family: 'Noto Sans TC', sans-serif;
      }
    </style>
    <script>
      // 字体加载完成后切换
      document.fonts.ready.then(() => {
        document.documentElement.classList.add('loaded');
      });
    </script>
    
    <!-- SEO Component -->
    <SEO 
      title={title}
      description={description}
      image={image}
      canonicalURL={canonicalURL}
      type={type}
      publishedTime={publishedTime}
    />
    
    <!-- 追踪代码注入（Head） -->
    {headScripts && <script set:html={headScripts} />}
  </head>
  <body class="font-sans antialiased text-gray-800 bg-white">
    <!-- 追踪代码注入（Body） -->
    {bodyScripts && <script set:html={bodyScripts} />}
    
    <slot />
    
    <!-- 追踪代码注入（Foot） -->
    {footScripts && <script set:html={footScripts} />}
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  body {
    font-family: 'Noto Sans TC', sans-serif;
  }
  
  /* 跳过链接样式 - 无障碍功能 */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    background: #1a5f4a;
    color: white;
    padding: 8px 16px;
    z-index: 100;
    transition: top 0.3s;
    text-decoration: none;
    font-weight: 500;
  }
  
  .skip-link:focus {
    top: 0;
  }
</style>
