---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import { getCollection } from 'astro:content';
// import SpeedInsights from "@vercel/speed-insights/astro"; // 已注释 - Google Ads 审核期间移除

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  type?: string;
  publishedTime?: string;
}

const { 
  title, 
  description = "缅甸翡翠定制专家｜15 年匠心传承",
  image,
  canonicalURL,
  type = 'website',
  publishedTime
} = Astro.props;

// 获取追踪代码配置
const trackingCodesCollection = await getCollection('tracking_codes');
const trackingCodes = trackingCodesCollection.find(c => c.id === 'config' || c.slug === 'config');
const headScripts = trackingCodes?.data.head_scripts || '';
const bodyScripts = trackingCodes?.data.body_scripts || '';
const footScripts = trackingCodes?.data.foot_scripts || '';
---

<!-- 跳过链接 - 无障碍功能 -->
<a href="#main-content" class="skip-link">
  跳转到主要内容
</a>

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- CDN 预连接优化 -->
    <!-- <link rel="dns-prefetch" href="//vercel-dns.com" /> 已注释 - Google Ads 审核期间移除 -->
    <!-- <link rel="preconnect" href="https://vercel-dns.com" /> 已注释 - Google Ads 审核期间移除 -->
    
    <!-- 图片预加载 - 首屏关键资源 -->
    <link 
      rel="preload" 
      as="image" 
      href="/images/person2.png"
      media="(max-width: 768px)"
      fetchpriority="high"
    />
    <link 
      rel="preload" 
      as="image" 
      href="/images/person1.png"
      media="(min-width: 769px)"
      fetchpriority="high"
    />
    
    <!-- Google Fonts 预加载和字体优化 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link 
      rel="preload" 
      as="style" 
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700&display=swap" 
    />
    <link 
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&display=swap" 
      rel="stylesheet" 
    />
    <style>
      /* 字体加载优化 - 避免 FOIT */
      @font-face {
        font-family: 'Noto Sans TC Fallback';
        src: local('Arial');
        ascent-override: 100%;
        descent-override: 30%;
        line-gap-override: 0%;
        size-adjust: 107%;
      }
      html {
        font-family: 'Noto Sans TC Fallback', sans-serif;
      }
      html.loaded {
        font-family: 'Noto Sans TC', sans-serif;
      }
    </style>
    <script>
      // 字体加载完成后切换
      document.fonts.ready.then(() => {
        document.documentElement.classList.add('loaded');
      });
    </script>
    
    <!-- SEO Component -->
    <SEO 
      title={title}
      description={description}
      image={image}
      canonicalURL={canonicalURL}
      type={type}
      publishedTime={publishedTime}
    />
    
    <!-- 追踪代码注入（Head） -->
    {headScripts && <Fragment set:html={headScripts} />}
    
    <!-- Vercel Speed Insights - 性能监控 -->
    <!-- <SpeedInsights /> 已注释 - Google Ads 审核期间移除 -->
  </head>
  <body class="font-sans antialiased text-gray-800 bg-white">
    <!-- 追踪代码注入（Body） -->
    {bodyScripts && <Fragment set:html={bodyScripts} />}
    
    <slot />
    
    <!-- 追踪代码注入（Foot） -->
    {footScripts && <Fragment set:html={footScripts} />}
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  body {
    font-family: 'Noto Sans TC', sans-serif;
  }
  
  /* 跳过链接样式 - 无障碍功能 */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    background: #1a5f4a;
    color: white;
    padding: 8px 16px;
    z-index: 100;
    transition: top 0.3s;
    text-decoration: none;
    font-weight: 500;
  }
  
  .skip-link:focus {
    top: 0;
  }
</style>
