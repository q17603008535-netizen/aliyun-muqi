---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Video from '../components/Video.astro';
import About from '../components/About.astro';
import Trust from '../components/Trust.astro';
import Products from '../components/Products.astro';
import KnowledgeWindow from '../components/knowledge/KnowledgeWindow.astro';
import WhyUs from '../components/WhyUs.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import FloatingContact from '../components/FloatingContact.astro';
import FreeGifts from '../components/FreeGifts.astro';
import PainPoints from '../components/PainPoints.astro';
import PriceComparison from '../components/PriceComparison.astro';

import { getCollection } from 'astro:content';

const contactData = await getCollection('contact');
const contacts = contactData
  .filter(c => c.data.visible)
  .sort((a, b) => (a.data.order || 1) - (b.data.order || 1))
  .map(c => c.data);

const productsData = await getCollection('products');
const products = productsData.map(p => p.data);

const productsConfigData = await getCollection('products_config');
const productsConfig = productsConfigData[0]?.data || {};

const testimonialsData = await getCollection('testimonials');
const testimonials = testimonialsData.map(t => t.data);

const testimonialsConfigData = await getCollection('testimonials_config');
const testimonialsConfig = testimonialsConfigData[0]?.data || {};

const heroData = await getCollection('hero');
const hero = heroData[0]?.data || {};

const aboutData = await getCollection('about');
const about = aboutData[0]?.data || {};

const trustData = await getCollection('trust');
const trust = trustData[0]?.data || {};

const whyUsData = await getCollection('why_us');
const whyUs = whyUsData[0]?.data || {};

const settingsData = await getCollection('settings');
const settings = settingsData[0]?.data || {};

const freeGiftsData = await getCollection('free_gifts');
const freeGifts = freeGiftsData[0]?.data || {};

const painPointsData = await getCollection('pain_points');
const painPoints = painPointsData[0]?.data || {};

const priceComparisonData = await getCollection('price_comparison');
const priceComparison = priceComparisonData[0]?.data || {};

const urgencySettingsData = await getCollection('urgency_settings');
const urgencySettings = urgencySettingsData[0]?.data || { enabled: false, messages: [] };

const urgencyMessage = urgencySettings.enabled && urgencySettings.messages?.length > 0 
  ? urgencySettings.messages.find((m: any) => m.position === 'hero' || m.position === 'all')?.text || ""
  : "";
---

<Layout title="沐祁珠寶 - 缅甸翡翠定制专家｜15 年匠心传承">
  <Navbar settings={settings} />
  
  <main>
    <Hero hero={hero} contacts={contacts} urgencyMessage={urgencyMessage} />
    <Video youtubeUrl={hero.youtube_url} />
    <FreeGifts freeGifts={freeGifts} contacts={contacts} urgencyMessage={urgencyMessage} />
    <PainPoints painPoints={painPoints} contacts={contacts} urgencyMessage={urgencyMessage} />
    <About about={about} />
    <Trust trust={trust} />
    <PriceComparison priceComparison={priceComparison} contacts={contacts} urgencyMessage={urgencyMessage} />
    <Products products={products} productsConfig={productsConfig} contacts={contacts} />
    <!-- <KnowledgeWindow /> 已注释 - Google Ads 审核期间隐藏科普页面 -->
    <WhyUs whyUs={whyUs} />
    <Testimonials testimonials={testimonials} testimonialsConfig={testimonialsConfig} />
    <Contact contacts={contacts} />
  </main>
  
  <Footer settings={settings} />
  
  <FloatingContact contacts={contacts} />
</Layout>

<style is:global>
  section[id] {
    scroll-margin-top: 4rem;
  }
</style>

<script hoist>
  // 优化：延迟加载非关键交互
  function initFadeInAnimations() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    });

    document.querySelectorAll('.fade-in-section').forEach(section => {
      observer.observe(section);
    });
  }

  // 使用 requestIdleCallback 或 setTimeout 延迟初始化
  if ('requestIdleCallback' in window) {
    requestIdleCallback(() => {
      initFadeInAnimations();
    });
  } else {
    setTimeout(initFadeInAnimations, 100);
  }
</script>

<script hoist>
  // 无障碍访问初始化
  function initAccessibility() {
    // 模态框管理
    const modal = document.getElementById('contact-modal');
    const modalBtn = document.getElementById('contact-modal-btn');
    const closeBtn = document.querySelector('.close-modal-btn');
    const overlay = document.querySelector('.modal-overlay');
    
    if (modal && modalBtn && closeBtn) {
      let previousActiveElement = null as HTMLElement | null;
      
      function openModal() {
        previousActiveElement = document.activeElement as HTMLElement;
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        modal.setAttribute('aria-hidden', 'false');
        
        // 聚焦到第一个可聚焦元素
        const firstFocusable = modal.querySelector<HTMLElement>('button, [href], input');
        firstFocusable?.focus();
        
        // 焦点陷阱
        modal.addEventListener('keydown', handleFocusTrap);
      }
      
      function closeModal() {
        modal.classList.add('hidden');
        document.body.style.overflow = '';
        modal.setAttribute('aria-hidden', 'true');
        previousActiveElement?.focus();
        modal.removeEventListener('keydown', handleFocusTrap);
      }
      
      function handleFocusTrap(e: KeyboardEvent) {
        if (e.key !== 'Tab') return;
        
        const focusableElements = modal.querySelectorAll<HTMLElement>(
          'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
        );
        const first = focusableElements[0];
        const last = focusableElements[focusableElements.length - 1];
        
        if (e.shiftKey && document.activeElement === first) {
          last.focus();
          e.preventDefault();
        } else if (!e.shiftKey && document.activeElement === last) {
          first.focus();
          e.preventDefault();
        }
      }
      
      modalBtn.addEventListener('click', openModal);
      closeBtn.addEventListener('click', closeModal);
      overlay?.addEventListener('click', closeModal);
      
      // Escape 键关闭
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
          closeModal();
        }
      });
    }
    
    // 产品联系模态框
    const productModal = document.getElementById('product-contact-modal');
    const productBtns = document.querySelectorAll('.product-contact-btn');
    const productClose = document.querySelector('.product-modal-close');
    const productOverlay = document.querySelector('.product-modal-overlay');
    
    if (productModal && productClose) {
      let previousActiveElement = null as HTMLElement | null;
      
      function openProductModal() {
        previousActiveElement = document.activeElement as HTMLElement;
        productModal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        productModal.setAttribute('aria-hidden', 'false');
        
        const firstFocusable = productModal.querySelector<HTMLElement>('button, [href], input');
        firstFocusable?.focus();
        
        productModal.addEventListener('keydown', handleProductFocusTrap);
      }
      
      function closeProductModal() {
        productModal.classList.add('hidden');
        document.body.style.overflow = '';
        productModal.setAttribute('aria-hidden', 'true');
        previousActiveElement?.focus();
        productModal.removeEventListener('keydown', handleProductFocusTrap);
      }
      
      function handleProductFocusTrap(e: KeyboardEvent) {
        if (e.key !== 'Tab') return;
        
        const focusableElements = productModal.querySelectorAll<HTMLElement>(
          'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
        );
        const first = focusableElements[0];
        const last = focusableElements[focusableElements.length - 1];
        
        if (e.shiftKey && document.activeElement === first) {
          last.focus();
          e.preventDefault();
        } else if (!e.shiftKey && document.activeElement === last) {
          first.focus();
          e.preventDefault();
        }
      }
      
      productBtns.forEach(btn => {
        btn.addEventListener('click', openProductModal);
      });
      
      productClose.addEventListener('click', closeProductModal);
      productOverlay?.addEventListener('click', closeProductModal);
      
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !productModal.classList.contains('hidden')) {
          closeProductModal();
        }
      });
    }
    
    // 键盘导航增强
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        const target = e.target as HTMLElement;
        if (target.tagName === 'BUTTON' || target.getAttribute('role') === 'button') {
          e.preventDefault();
          target.click();
        }
      }
    });
  }
  
  // DOM 加载完成后初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAccessibility);
  } else {
    initAccessibility();
  }
</script>
