        </ul>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl font-semibold mb-4 text-gray-800">8. 更新與解釋權</h2>
        
        <h3 class="font-semibold text-gray-900 mt-4 mb-2">8.1 條款更新</h3>
        <ul class="list-disc list-inside space-y-1 text-gray-700">
