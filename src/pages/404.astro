---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const settings = await getCollection('settings');
const setting = settings[0]?.data || {};

interface ContactItem {
  type: string;
  value: string;
  label: string;
}

const contacts: ContactItem[] = [
  { type: 'line', value: 'luotianfeicui', label: 'Line ID' },
  { type: 'wechat', value: 'luotianfeicui', label: '微信' }
];
---

<Layout title="404 - 页面未找到 | 沐祁珠寶" description="您访问的页面不存在，请返回首页查看我们的翡翠定制服务。">
  <Navbar settings={setting} />
  <main class="min-h-screen flex items-center justify-center bg-gradient-to-b from-white to-stone-50 py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="mb-8">
        <div class="text-9xl font-bold text-primary/20 mb-4">404</div>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">页面未找到</h1>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-8">
          抱歉，您访问的页面不存在或已被移除。请检查网址是否正确，或返回首页浏览我们的翡翠原石产品。
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="bg-white p-6 rounded-2xl shadow-lg border border-gray-100">
          <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mb-4 mx-auto">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">返回首页</h3>
          <p class="text-gray-600 mb-4">浏览最新翡翠原石产品和专业服务</p>
          <a 
            href="/" 
            class="inline-flex items-center justify-center px-6 py-3 bg-primary text-white font-medium rounded-lg btn-hover shadow-lg transition-all duration-300"
          >
            返回首页
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <div class="bg-white p-6 rounded-2xl shadow-lg border border-gray-100">
          <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mb-4 mx-auto">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">联系我们</h3>
          <p class="text-gray-600 mb-4">需要帮助？我们的翡翠专家随时为您服务</p>
          <a 
            href="/#contact" 
            class="inline-flex items-center justify-center px-6 py-3 border-2 border-primary text-primary font-medium rounded-lg hover:bg-primary hover:text-white transition-all duration-300"
          >
            联系客服
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </a>
        </div>
      </div>

      <div class="bg-white p-6 rounded-2xl shadow-lg border border-gray-100 max-w-3xl mx-auto">
        <h3 class="text-xl font-semibold text-gray-900 mb-4">您可能还想浏览：</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <a href="/#products" class="group p-4 bg-stone-50 hover:bg-primary/5 rounded-lg border border-gray-200 hover:border-primary/30 transition-all duration-300">
            <div class="text-primary mb-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <h4 class="font-medium text-gray-900 group-hover:text-primary transition-colors">产品展示</h4>
            <p class="text-sm text-gray-600 mt-1">查看最新翡翠原石</p>
          </a>
          
          <a href="/#about" class="group p-4 bg-stone-50 hover:bg-primary/5 rounded-lg border border-gray-200 hover:border-primary/30 transition-all duration-300">
            <div class="text-primary mb-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h4 class="font-medium text-gray-900 group-hover:text-primary transition-colors">关于我们</h4>
            <p class="text-sm text-gray-600 mt-1">了解专业翡翠买手</p>
          </a>
          
          <a href="/#why_us" class="group p-4 bg-stone-50 hover:bg-primary/5 rounded-lg border border-gray-200 hover:border-primary/30 transition-all duration-300">
            <div class="text-primary mb-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h4 class="font-medium text-gray-900 group-hover:text-primary transition-colors">为什么选择我们</h4>
            <p class="text-sm text-gray-600 mt-1">15年专业经验保证</p>
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer settings={setting} contacts={contacts} />
</Layout>

<style>
  .btn-hover {
    transition: all 0.3s ease;
  }
  .btn-hover:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(26, 95, 74, 0.3);
  }
  .btn-hover:active {
    transform: translateY(0);
  }
</style>